<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Activity 启动到 Compose 接管绘制之间的窗口背景色。
        必须与 Theme.kt 中 lightColorScheme().background = DefaultBrandSurfaceLight (#F6FAFF)
        完全一致，否则会有"白闪"或"色偏"。
        设置独立的颜色资源是因为 themes.xml 是静态 XML，无法读 Compose 的运行时决策。
    -->
    <color name="window_background">#F6FAFF</color>
</resources>
